<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NimbleBlocks.Resources.Logo"
             x:Name="LogoView">
    
    <Grid WidthRequest="120" HeightRequest="120">
        <!-- Logo Image -->
        <Image x:Name="LogoImage"
               Aspect="AspectFit"
               HorizontalOptions="Center" 
               VerticalOptions="Center"
               WidthRequest="120" 
               HeightRequest="120"/>
        
        <!-- Fallback Logo (if image doesn't load) -->
        <StackLayout x:Name="FallbackLogo" 
                     IsVisible="False"
                     HorizontalOptions="Center" 
                     VerticalOptions="Center">
            <Label Text="NB" 
                   FontSize="48" 
                   FontAttributes="Bold" 
                   TextColor="#FF4500" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center"/>
        </StackLayout>
    </Grid>
</ContentView>
